rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the request authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: is the requesting user the owner
    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Helper: is the user a member of a group
    function isGroupMember(groupId) {
      return request.auth.uid in 
        get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
    }

    // users — only the user themselves
    match /users/{uid} {
      allow read, write: if isAuth() && isOwner(uid);
    }

    // groups — members can read, creator can write settings
    match /groups/{groupId} {
      allow read: if isAuth() && 
        request.auth.uid in resource.data.memberUids;
      allow create: if isAuth();
      allow update: if isAuth() && 
        isOwner(resource.data.createdBy);
      allow delete: if isAuth() && 
        isOwner(resource.data.createdBy);
    }

    // expenses — owner or group member can read
    // only owner can write
    match /expenses/{expenseId} {
      allow read: if isAuth() && (
        isOwner(resource.data.ownerId) ||
        (resource.data.groupId != null && 
         isGroupMember(resource.data.groupId))
      );
      allow create: if isAuth() && 
        isOwner(request.resource.data.ownerId);
      allow update, delete: if isAuth() && 
        isOwner(resource.data.ownerId);
    }

    // investments — owner only
    match /investments/{investmentId} {
      allow read, write: if isAuth() && 
        isOwner(resource.data.ownerId);
      allow create: if isAuth() && 
        isOwner(request.resource.data.ownerId);
    }

    // budgets — owner only
    match /budgets/{budgetId} {
      allow read, write: if isAuth() && 
        isOwner(resource.data.ownerId);
      allow create: if isAuth() && 
        isOwner(request.resource.data.ownerId);
    }

    // merchantPatterns — user only
    match /merchantPatterns/{patternId} {
      allow read, write: if isAuth() && 
        isOwner(resource.data.userId);
      allow create: if isAuth() && 
        isOwner(request.resource.data.userId);
    }

    // customCategories — user only
    match /customCategories/{categoryId} {
      allow read, write: if isAuth() && 
        isOwner(resource.data.userId);
      allow create: if isAuth() && 
        isOwner(request.resource.data.userId);
    }

    // notifications — recipient only
    match /notifications/{notificationId} {
      allow read, write: if isAuth() && 
        isOwner(resource.data.userId);
    }

    // aiInsights — read by relevant user or group member
    // write only via Admin SDK (server) — deny all client writes
    match /aiInsights/{insightId} {
      allow read: if isAuth() && (
        isOwner(resource.data.scopeId) ||
        (resource.data.scopeType == 'group' && 
         isGroupMember(resource.data.scopeId))
      );
      allow write: if false;
    }

    // smsParseCache — authenticated users can read
    // write only via server API routes
    match /smsParseCache/{hash} {
      allow read: if isAuth();
      allow write: if false;
    }
  }
}
